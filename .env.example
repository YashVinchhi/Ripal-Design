# Copy this file to .env and fill with real values.
# Local Docker defaults are included so `docker compose up -d --build` works out of the box.

# App
APP_ENV=production
APP_BASE_URL=http://localhost:8080
APP_PORT=8080

# Database (App connection)
DB_HOST=db
DB_PORT=3306
DB_HOST_PORT=3307
DB_NAME=Ripal-Design
DB_USER=app
DB_PASS=app_password

# Database (MySQL root user for container init/admin)
MYSQL_ROOT_PASSWORD=root_password

# Container image overrides (used by docker-compose.prod.yml)
IMAGE_NAME=ghcr.io/yashvinchhi/ripal-design:latest
MYSQL_IMAGE=ghcr.io/yashvinchhi/ripal-design-mysql:latest

# Payments
PAYMENT_PROVIDER=paypal
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret

# Mail / SMTP
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_FROM=no-reply@example.com
MAIL_FROM_NAME=Ripal Design

# Legacy SMTP aliases (for compatibility)
SMTP_HOST=smtp.example.com
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_FROM=no-reply@example.com

# Test mail credentials (non-production placeholders)
TEST_MAIL_USERNAME=test@example.com
TEST_MAIL_PASSWORD=replace_me

# UPI / billing placeholders
UPI_VPA=your-vpa@bank
UPI_NAME=Ripal Design

# Public contact CTAs
PHONE_NUMBER=+919426789012
WHATSAPP_NUMBER=919426789012

# Homepage social proof strip
HERO_PROOF_PROJECTS=50+
HERO_PROOF_YEARS=10+
HERO_PROOF_SATISFACTION=100%
