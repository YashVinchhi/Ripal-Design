########################################
# APPLICATION
########################################
APP_NAME="Ripal Design"
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=http://localhost
APP_BASE_URL=http://localhost:8080
APP_PORT=8080

########################################
# SECURITY
########################################
SECURITY_ENABLE_HSTS=false
SECURITY_ENABLE_CSP=true
SECURITY_CSP_POLICY="default-src 'self';"

########################################
# DATABASE (Application)
########################################
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_HOST_PORT=3307
DB_DATABASE=ripal_design
DB_USERNAME=app
DB_PASSWORD=app_password

########################################
# DATABASE (Container / Root Access)
########################################
MYSQL_ROOT_PASSWORD=root_password

########################################
# DOCKER / IMAGE CONFIG
########################################
IMAGE_NAME=ghcr.io/yashvinchhi/ripal-design:latest
MYSQL_IMAGE=ghcr.io/yashvinchhi/ripal-design-mysql:latest

########################################
# MAIL / SMTP
########################################
MAIL_DRIVER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="Ripal Design"

# Legacy SMTP compatibility (optional)
SMTP_HOST=${MAIL_HOST}
SMTP_PORT=${MAIL_PORT}
SMTP_USER=${MAIL_USERNAME}
SMTP_PASS=${MAIL_PASSWORD}
SMTP_FROM=${MAIL_FROM_ADDRESS}

########################################
# PAYMENT CONFIGURATION
########################################
PAYMENT_PROVIDER=razorpay
PAYMENT_CURRENCY=INR

RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

########################################
# TEST / SANDBOX CREDENTIALS
########################################
TEST_MAIL_USERNAME=test@example.com
TEST_MAIL_PASSWORD=replace_me

########################################
# BILLING / UPI
########################################
UPI_VPA=your-vpa@bank
UPI_NAME="Ripal Design"

########################################
# CONTACT INFORMATION
########################################
PHONE_NUMBER=+919426789012
WHATSAPP_NUMBER=919426789012

########################################
# HOMEPAGE METRICS (SOCIAL PROOF)
########################################
HERO_PROOF_PROJECTS=50+
HERO_PROOF_YEARS=10+
HERO_PROOF_SATISFACTION=100%