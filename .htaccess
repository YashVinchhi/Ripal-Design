# Apache per-directory PHP values (works with mod_php)
<IfModule mod_php7.c>
    php_value upload_max_filesize 450M
    php_value post_max_size 460M
    php_value memory_limit 1024M
    php_value max_execution_time 600
    php_value max_input_time 600
</IfModule>
<IfModule mod_php8.c>
    php_value upload_max_filesize 450M
    php_value post_max_size 460M
    php_value memory_limit 1024M
    php_value max_execution_time 600
    php_value max_input_time 600
</IfModule>

# Custom 404 Error Page
# Note: The leading slash ensures it's absolute to the domain root or handled via rewrite
ErrorDocument 404 /public/404.php

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # If project is in a subfolder, you might need RewriteBase /Thefinal/
    
    # Prevent direct access to includes, app, sql, etc.
    RewriteRule ^(app|sql|Common|includes|scripts|logs|storage|stubs|tests|vendor)/ - [F,L]
    
    # If the requested filename does not exist, and it's not a directory
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    # Then route to 404 page
    RewriteRule . /public/404.php [L]
    
    # SEO-friendly project slugs
    RewriteRule ^projects/([0-9]+)$ /projects/$1 [L,NC]
    # Redirect numeric project URLs to slug-based URL via internal PHP redirect (handled in project_details.php)
    RewriteRule ^projects/([A-Za-z0-9\-]+)/?$ /project_view.php?slug=$1 [L,QSA]
</IfModule>

# -------------------------
# Performance: caching, compression
# -------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    # Images: 30 days
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"

    # CSS/JS: 7 days
    ExpiresByType text/css "access plus 7 days"
    ExpiresByType application/javascript "access plus 7 days"
    ExpiresByType text/javascript "access plus 7 days"

    # HTML: no cache
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
    # Prevent caching for HTML (ensure always revalidated)
    <FilesMatch "\.(html|php)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>

    # Cache bust via query string recommended for CSS/JS when versioned
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "public, max-age=604800"
    </FilesMatch>
</IfModule>

# GZIP compression
<IfModule mod_deflate.c>
    # Compress common text-based resources
    <IfModule mod_filter.c>
        AddOutputFilterByType DEFLATE text/plain text/css application/json application/javascript text/javascript application/xml application/xhtml+xml text/html
    </IfModule>
    # Don't compress images
    SetEnvIfNoCase Request_URI \.(?:gif|jpe?g|png|webp|avif)$ no-gzip
</IfModule>

